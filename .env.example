# Copy this to .env.local and fill in your values

# Anthropic / Claude API (server-side only — NEVER prefix with VITE_)
ANTHROPIC_API_KEY=sk-ant-...

# Firebase (client-side — get these from Firebase console > Project Settings > Your Apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Ollama - Free local LLM for translations (completely unlimited, no character limits)
# Installation: https://ollama.ai
# Run: ollama serve
# Download a model: ollama pull neural-chat (or mistral, llama2, etc.)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat
